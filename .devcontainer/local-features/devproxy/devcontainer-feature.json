{
	"id": "devproxy",
	"name": "Dev Proxy",
	"version": "1.0.0",
	"description": "Installs Microsoft Dev Proxy for API simulation and testing",
	"documentationURL": "https://aka.ms/devproxy",
	"installsAfter": [
		"ghcr.io/devcontainers/features/common-utils"
	],
	"options": {
		"version": {
			"type":"string",
			"description": "Dev Proxy version:",
			"proposals": [
				"latest",
				"2.3.4",
				"2.2.0",
				"2.1.0",
				"2.0.0",
				"1.3.0",
				"1.2.1",
				"1.1.0"
			],
			"default": "latest"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"garrytrinder.dev-proxy-toolkit@prerelease"
			]
		}
	}
}